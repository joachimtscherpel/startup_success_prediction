%% compile with:
%% colima start
%% docker run --rm -v "$(pwd)":/data minlag/mermaid-cli -i /data/flowchart_training.mmd  -o /data/flowchart_training.pdf -b white --pdfFit

%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#dbeafe", "primaryTextColor": "#1e3a5f", "primaryBorderColor": "#93c5fd", "lineColor": "#60a5fa", "clusterBkg": "#f0f9ff", "clusterBorder": "#93c5fd", "edgeLabelBackground": "#ffffff", "fontSize": "20px", "fontFamily": "Arial, Helvetica, sans-serif"}}}%%
flowchart TD
    A["Start: Load preprocessed_data"]
    A --> C["For each combination<br/>(buyin_round, window_years)"]
    C --> P1
    subgraph P1 ["Parsing Pipeline (full dataset)"]
        direction TB
        D["FeatureExtractor,<br/>BuyInRoundExtractor,<br/>TargetExtractor"]
    end
    D --> E["MultiTargetTimeSeriesSplitter"]
    E --> G["For each quantile"]
    G --> P2

    subgraph P2 ["Binarizer Pipeline (per fold)"]
        direction TB
        B1["QuantileTargetBinarizer"]
    end

    B1 --> H["For each target"]
    H --> F["Extract X / y"]
    F --> P3
    subgraph P3 ["RandomizedSearchCV"]
        direction TB
        subgraph P3_inner ["Tunable Pipeline"]
            direction TB
            L["TargetColumnDropper,<br/>EmbeddingScoreMerger,<br/>TenYearTBYMerger,<br/>ColumnDropper,<br/>CatEncoder"] --> N["XGBWrapper with custom early stopping"]
        end
    end
    N --> O["Evaluate on train/test, SHAP"]
    O --> P{"More targets?"}
    P -- "Yes" --> H
    P -- "No" --> Q{"More quantiles?"}
    Q -- "Yes" --> G
    Q -- "No" --> U{"More folds?"}
    U -- "Yes" --> E
    U -- "No" --> V{"More combos?"}
    V -- "Yes" --> C
    V -- "No" --> W["End"]